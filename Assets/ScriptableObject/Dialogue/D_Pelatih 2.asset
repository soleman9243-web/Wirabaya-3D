  m_Name: D_Pelatih 2
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  nodes:
  - speakerName: Pelatih
    dialogueText: Kerja bagus. Tapi bertahan hidup di alam liar bukan hanya soal
      membuat api, melainkan juga menghindari ancaman.
    hasChoices: 0
    choices: []
    cameraID: NPC
    endDialogueAfterThis: 0
    jumpToNode: 0
    nextNodeId: 0
  - speakerName: Wirabaya
    dialogueText: Ancaman seperti apa yang Anda maksud?
    hasChoices: 0
    choices: []
    cameraID: Player
    endDialogueAfterThis: 0
    jumpToNode: 0
    nextNodeId: 0
  - speakerName: Wirabaya
    dialogueText: Ancaman seperti apa yang Anda maksud?
    hasChoices: 0
    choices: []
    cameraID: Player
    endDialogueAfterThis: 0
    jumpToNode: 0
    nextNodeId: 0
  - speakerName: Pelatih
    dialogueText: Lihat satu boneka penjaga di depan itu? Area merah di depannya
      adalah jarak pandangnya.
    hasChoices: 0
    choices: []
    cameraID: NPC
    endDialogueAfterThis: 0
    jumpToNode: 0
    nextNodeId: 0
  - speakerName: Wirabaya
    dialogueText: Saya melihatnya. Haruskah saya menghadapinya secara langsung?
    hasChoices: 0
    choices: []
    cameraID: Player
    endDialogueAfterThis: 0
    jumpToNode: 0
    nextNodeId: 0
  - speakerName: Pelatih
    dialogueText: Tidak kali ini. Mengendap-endaplah dari belakangnya, pastikan kau
      tidak terdeteksi, lalu lakukan Penyergapan (Takedown) secara diam-diam!
    hasChoices: 0
    choices: []
    cameraID: NPC
    endDialogueAfterThis: 0
    jumpToNode: 0
    nextNodeId: 0
