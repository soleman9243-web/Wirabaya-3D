  m_Script: {fileID: 11500000, guid: 3638fa539fefa1b4ca56cc4501fb6624, type: 3}
  m_Name: D_Pelatih 4
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  nodes:
  - speakerName: Pelatih
    dialogueText: Tangkisan yang sempurna! Kau memiliki refleks yang tajam.
    hasChoices: 0
    choices: []
    cameraID: NPC
    endDialogueAfterThis: 0
    jumpToNode: 0
    nextNodeId: 0
  - speakerName: Wirabaya
    dialogueText: Itu berkat instruksi Anda, Pelatih. Apakah ini akan menjadi ujian
      terakhir?
    hasChoices: 0
    choices: []
    cameraID: Player
    endDialogueAfterThis: 0
    jumpToNode: 0
    nextNodeId: 0
  - speakerName: Pelatih
    dialogueText: Tepat sekali. Sekarang kau sudah siap untuk pertarungan gaya bebas.
    hasChoices: 0
    choices: []
    cameraID: NPC
    endDialogueAfterThis: 0
    jumpToNode: 0
    nextNodeId: 0
  - speakerName: Wirabaya
    dialogueText: Berapa banyak musuh yang harus saya hadapi di dalam sana?
    hasChoices: 0
    choices: []
    cameraID: Player
    endDialogueAfterThis: 0
    jumpToNode: 0
    nextNodeId: 0
  - speakerName: Pelatih
    dialogueText: Masuklah ke arena luas di depan sana. Ada 5 boneka petarung yang
      telah menunggumu. Tunjukkan semua teknik yang telah kau pelajari dan hancurkan
      mereka berlima tanpa ampun!
    hasChoices: 0
    choices: []
    cameraID: NPC
    endDialogueAfterThis: 0
    jumpToNode: 0
    nextNodeId: 0
